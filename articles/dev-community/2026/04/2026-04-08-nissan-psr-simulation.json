  "summary": "<div class=\"highlight js-code-highlight\">\n<pre class=\"highlight html\"><code><span class=\"cp\">&lt;!DOCTYPE html&gt;</span>\n<span class=\"nt\">&lt;html</span> <span class=\"na\">lang=</span><span class=\"s\">\"ja\"</span><span class=\"nt\">&gt;</span>\n<span class=\"nt\">&lt;head&gt;</span>\n<span class=\"nt\">&lt;meta</span> <span class=\"na\">charset=</span><span class=\"s\">\"UTF-8\"</span><span class=\"nt\">&gt;</span>\n<span class=\"nt\">&lt;meta</span> <span class=\"na\">name=</span><span class=\"s\">\"viewport\"</span> <span class=\"na\">content=</span><span class=\"s\">\"width=device-width, initial-scale=1.0\"</span><span class=\"nt\">&gt;</span>\n<span class=\"nt\">&lt;title&gt;</span>日産PSR投資シミュレーション — Re:Nissan成功シナリオ<span class=\"nt\">&lt;/title&gt;</span>\n<span class=\"nt\">&lt;link</span> <span class=\"na\">href=</span><span class=\"s\">\"https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&amp;family=Noto+Sans+JP:wght@300;400;500;700&amp;display=swap\"</span> <span class=\"na\">rel=</span><span class=\"s\">\"stylesheet\"",
  "full_text": "<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>日産PSR投資シミュレーション — Re:Nissan成功シナリオ</title>\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Noto+Sans+JP:wght@300;400;500;700&display=swap\" rel=\"stylesheet\">\n<style>\n:root{--bg:#0a0b0d;--surface:#12141a;--surface2:#1a1d26;--border:#2a2d38;--text:#e8e6e1;--text-muted:#8a8d96;--text-dim:#5a5d66;--accent:#d4a853;--green:#4ade80;--red:#f87171;--blue:#60a5fa;--cyan:#22d3ee}\n*{margin:0;padding:0;box-sizing:border-box}\nbody{background:var(--bg);color:var(--text);font-family:'Noto Sans JP','DM Mono',monospace;font-weight:300;line-height:1.7}\n.container{max-width:1000px;margin:0 auto;padding:32px 20px 80px}\nh1{font-size:22px;font-weight:700;margin-bottom:4px;color:var(--accent)}\n.sub{font-size:12px;color:var(--text-muted);margin-bottom:32px}\n.section{margin-bottom:36px}\n.section-title{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:16px;display:flex;align-items:center;gap:10px}\n.section-title::after{content:'';flex:1;height:1px;background:var(--border)}\n/* Portfolio table */\ntable{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:16px}\nth{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-dim);background:var(--surface);padding:10px 12px;text-align:right;border-bottom:1px solid var(--border)}\nth:first-child{text-align:left}\ntd{padding:8px 12px;text-align:right;border-bottom:1px solid var(--border);font-family:'DM Mono',monospace;color:var(--text-muted)}\ntd:first-child{text-align:left;color:var(--text);font-weight:400}\ntr:hover{background:rgba(212,168,83,.03)}\n.highlight td{color:var(--accent)!important;font-weight:500}\n.neg{color:var(--red)!important}\n.pos{color:var(--green)!important}\n/* Sliders */\n.controls{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px;margin-bottom:24px}\n.control-row{display:flex;align-items:center;gap:16px;margin-bottom:14px;flex-wrap:wrap}\n.control-row:last-child{margin-bottom:0}\n.control-label{font-size:12px;color:var(--text-muted);min-width:180px}\n.control-value{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--accent);min-width:80px;text-align:right}\ninput[type=range]{flex:1;min-width:150px;accent-color:var(--accent);background:transparent;height:4px}\n/* Result cards */\n.results{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px}\n.result-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:18px;text-align:center;position:relative;overflow:hidden}\n.result-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}\n.result-card.gold::after{background:var(--accent)}.result-card.green::after{background:var(--green)}.result-card.red::after{background:var(--red)}.result-card.blue::after{background:var(--blue)}.result-card.cyan::after{background:var(--cyan)}\n.r-label{font-size:10px;color:var(--text-dim);font-family:'DM Mono',monospace;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}\n.r-value{font-family:'DM Mono',monospace;font-size:22px;font-weight:500}\n.result-card.gold .r-value{color:var(--accent)}.result-card.green .r-value{color:var(--green)}.result-card.red .r-value{color:var(--red)}.result-card.blue .r-value{color:var(--blue)}.result-card.cyan .r-value{color:var(--cyan)}\n.r-note{font-size:10px;color:var(--text-dim);margin-top:2px}\n/* Scenario table */\n.scenario-table td.year{color:var(--cyan);font-weight:500}\n/* Callout */\n.callout{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:0 8px 8px 0;padding:18px 22px;margin-bottom:20px;font-size:12px;color:var(--text-muted);line-height:1.8}\n.callout strong{color:var(--text);font-weight:500}\n/* Bar */\n.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}\n.bar-label{font-size:11px;color:var(--text-muted);min-width:100px;text-align:right}\n.bar-track{flex:1;height:20px;background:var(--surface2);border-radius:3px;overflow:hidden;position:relative}\n.bar-fill{height:100%;border-radius:3px;transition:width .3s}\n.bar-pct{font-family:'DM Mono',monospace;font-size:10px;color:var(--text-dim);min-width:50px}\n.footer{margin-top:48px;padding-top:16px;border-top:1px solid var(--border);font-size:10px;color:var(--text-dim);font-family:'DM Mono',monospace;text-align:center;line-height:1.8}\n</style>\n</head>\n<body>\n<div class=\"container\">\n\n<h1>日産PSR投資シミュレーション</h1>\n<p class=\"sub\">Re:Nissan成功シナリオ — ポートフォリオ全体への影響を試算</p>\n\n<!-- Current Portfolio -->\n<div class=\"section\">\n<div class=\"section-title\">現在のポートフォリオ</div>\n<table>\n<thead><tr><th>銘柄</th><th>株数</th><th>時価</th><th>比率</th><th>性格</th></tr></thead>\n<tbody>\n<tr><td>2674 ハードオフ</td><td>15,000</td><td>3,105万</td><td>24.9%</td><td>配当</td></tr>\n<tr><td>8291 日産東京HD</td><td>50,000</td><td>2,580万</td><td>20.7%</td><td>配当</td></tr>\n<tr><td>5869 早稲田学習研究会</td><td>20,000</td><td>2,644万</td><td>21.2%</td><td>配当</td></tr>\n<tr><td>2411 現代エージェンシー</td><td>50,000</td><td>2,380万</td><td>19.1%</td><td>配当</td></tr>\n<tr class=\"highlight\"><td>7201 日産自動車</td><td>50,000</td><td>1,747万</td><td>14.0%</td><td>PSR</td></tr>\n<tr><td><strong>合計</strong></td><td></td><td><strong>12,456万</strong></td><td>100%</td><td></td></tr>\n</tbody>\n</table>\n</div>\n\n<!-- Re:Nissan Assumptions -->\n<div class=\"section\">\n<div class=\"section-title\">Re:Nissan 成功シナリオの前提</div>\n<div class=\"controls\">\n<div class=\"control-row\">\n<span class=\"control-label\">FY2026 売上高（兆円）</span>\n<input type=\"range\" id=\"sl_revenue\" min=\"10\" max=\"14\" step=\"0.1\" value=\"11.5\">\n<span class=\"control-value\" id=\"v_revenue\">11.5兆</span>\n</div>\n<div class=\"control-row\">\n<span class=\"control-label\">FY2026 営業利益率</span>\n<input type=\"range\" id=\"sl_opm\" min=\"0\" max=\"8\" step=\"0.5\" value=\"6\">\n<span class=\"control-value\" id=\"v_opm\">6.0%</span>\n</div>\n<div class=\"control-row\">\n<span class=\"control-label\">正常化PER（倍）</span>\n<input type=\"range\" id=\"sl_per\" min=\"5\" max=\"20\" step=\"0.5\" value=\"10\">\n<span class=\"control-value\" id=\"v_per\">10.0倍</span>\n</div>\n<div class=\"control-row\">\n<span class=\"control-label\">純利益率 / 営業利益率</span>\n<input type=\"range\" id=\"sl_net_ratio\" min=\"30\" max=\"80\" step=\"5\" value=\"60\">\n<span class=\"control-value\" id=\"v_net_ratio\">60%</span>\n</div>\n<div class=\"control-row\">\n<span class=\"control-label\">発行済株式数（億株）</span>\n<input type=\"range\" id=\"sl_shares\" min=\"30\" max=\"40\" step=\"0.5\" value=\"35.9\">\n<span class=\"control-value\" id=\"v_shares\">35.9億</span>\n</div>\n</div>\n</div>\n\n<!-- Simulation Results -->\n<div class=\"section\">\n<div class=\"section-title\">シミュレーション結果</div>\n<div class=\"results\" id=\"results\"></div>\n</div>\n\n<!-- PSR Reverse Engineering -->\n<div class=\"section\">\n<div class=\"section-title\">フィッシャーPSR逆算</div>\n<div class=\"results\" id=\"fisher_results\"></div>\n</div>\n\n<!-- Portfolio Impact -->\n<div class=\"section\">\n<div class=\"section-title\">ポートフォリオへの影響</div>\n<div class=\"results\" id=\"portfolio_results\"></div>\n\n<div style=\"margin-top:16px\">\n<div class=\"bar-row\">\n<span class=\"bar-label\">配当4銘柄</span>\n<div class=\"bar-track\"><div class=\"bar-fill\" id=\"bar_div\" style=\"background:var(--blue)\"></div></div>\n<span class=\"bar-pct\" id=\"bar_div_pct\"></span>\n</div>\n<div class=\"bar-row\">\n<span class=\"bar-label\">日産（PSR）</span>\n<div class=\"bar-track\"><div class=\"bar-fill\" id=\"bar_nissan\" style=\"background:var(--accent)\"></div></div>\n<span class=\"bar-pct\" id=\"bar_nissan_pct\"></span>\n</div>\n</div>\n</div>\n\n<!-- Timeline -->\n<div class=\"section\">\n<div class=\"section-title\">Re:Nissan成功シナリオ タイムライン</div>\n<table class=\"scenario-table\">\n<thead><tr><th>時期</th><th>売上高</th><th>営業利益</th><th>OPM</th><th>想定株価</th><th>日産時価</th><th>PF合計</th></tr></thead>\n<tbody id=\"timeline_body\"></tbody>\n</table>\n</div>\n\n<div class=\"callout\" id=\"summary_callout\"></div>\n\n<div class=\"footer\">\n シミュレーション前提：配当4銘柄は現在価格で固定。日産の株価はPER×EPS逆算。<br>\n 実際の株価は市場環境・為替・関税政策等により大きく変動します。投資判断はご自身の責任で。<br>\n Data: Re:Nissan Plan (2025/05/13) / IRBank / 有報第126期\n</div>\n\n</div>\n\n<script>\nconst NISSAN_SHARES_HELD = 50000;\nconst DIV4_VALUE = 124560000 - 17470000; // 配当4銘柄合計\nconst CURRENT_NISSAN_VALUE = 17470000;\nconst CURRENT_NISSAN_PRICE = CURRENT_NISSAN_VALUE / NISSAN_SHARES_HELD; // 349.4円\n\nfunction fmt(n) {\n if (Math.abs(n) >= 100000000) return (n / 100000000).toFixed(1) + '億';\n if (Math.abs(n) >= 10000) return (n / 10000).toFixed(0) + '万';\n return n.toFixed(0);\n}\n\nfunction fmtYen(n) { return '¥' + n.toFixed(0).replace(/\\B(?=(\\d{3})+(?!\\d))/g, ','); }\nfunction fmtPct(n) { return (n >= 0 ? '+' : '') + n.toFixed(1) + '%'; }\n\nfunction calc() {\n const revenue = parseFloat(document.getElementById('sl_revenue').value); // 兆円\n const opm = parseFloat(document.getElementById('sl_opm').value); // %\n const per = parseFloat(document.getElementById('sl_per').value);\n const netRatio = parseFloat(document.getElementById('sl_net_ratio').value) / 100;\n const sharesB = parseFloat(document.getElementById('sl_shares').value); // 億株\n const shares = sharesB * 100000000;\n\n // Update labels\n document.getElementById('v_revenue').textContent = revenue.toFixed(1) + '兆';\n document.getElementById('v_opm').textContent = opm.toFixed(1) + '%';\n document.getElementById('v_per').textContent = per.toFixed(1) + '倍';\n document.getElementById('v_net_ratio').textContent = (netRatio * 100).toFixed(0) + '%';\n document.getElementById('v_shares').textContent = sharesB.toFixed(1) + '億';\n\n // Core calculations\n const revenueBn = revenue * 1000000000000; // 円\n const opProfit = revenueBn * (opm / 100);\n const netProfit = opProfit * netRatio;\n const eps = netProfit / shares;\n const targetPrice = eps * per;\n const targetMarketCap = targetPrice * shares;\n const targetPSR = targetMarketCap / revenueBn;\n\n // Current\n const currentMarketCap = 1474400000000; // 1.47兆\n const currentPSR = currentMarketCap / 12633200000000;\n\n // Upside\n const upside = (targetPrice / CURRENT_NISSAN_PRICE - 1) * 100;\n const nissanNewValue = NISSAN_SHARES_HELD * targetPrice;\n const pfTotal = DIV4_VALUE + nissanNewValue;\n const pfChange = (pfTotal / 124560000 - 1) * 100;\n const nissanWeight = nissanNewValue / pfTotal * 100;\n\n // Fisher reverse\n const fisherTheory = revenueBn * 0.05 * 15; // 純利益率5% × PER15\n\n // Results\n const rHTML = `\n <div class=\"result-card gold\"><div class=\"r-label\">想定株価</div><div class=\"r-value\">${fmtYen(targetPrice)}</div><div class=\"r-note\">現在 ¥${CURRENT_NISSAN_PRICE.toFixed(0)} → ${fmtPct(upside)}</div></div>\n <div class=\"result-card ${upside >= 0 ? 'green' : 'red'}\"><div class=\"r-label\">上昇率</div><div class=\"r-value\">${fmtPct(upside)}</div><div class=\"r-note\">Re:Nissan成功時</div></div>\n <div class=\"result-card blue\"><div class=\"r-label\">想定時価総額</div><div class=\"r-value\">${(targetMarketCap/1000000000000).toFixed(2)}兆</div><div class=\"r-note\">現在 1.47兆</div></div>\n <div class=\"result-card cyan\"><div class=\"r-label\">想定EPS</div><div class=\"r-value\">${fmtYen(eps)}</div><div class=\"r-note\">PER ${per.toFixed(1)}倍で算出</div></div>\n <div class=\"result-card gold\"><div class=\"r-label\">営業利益</div><div class=\"r-value\">${(opProfit/100000000).toFixed(0)}億</div><div class=\"r-note\">OPM ${opm.toFixed(1)}%</div></div>\n <div class=\"result-card blue\"><div class=\"r-label\">純利益</div><div class=\"r-value\">${(netProfit/100000000).toFixed(0)}億</div><div class=\"r-note\">OP × ${(netRatio*100).toFixed(0)}%</div></div>\n `;\n document.getElementById('results').innerHTML = rHTML;\n\n // Fisher\n const fHTML = `\n <div class=\"result-card gold\"><div class=\"r-label\">現在PSR</div><div class=\"r-value\">${currentPSR.toFixed(3)}</div><div class=\"r-note\">基準: 0.75以下で買い</div></div>\n <div class=\"result-card ${targetPSR <= 0.75 ? 'green' : targetPSR <= 1.5 ? 'blue' : 'red'}\"><div class=\"r-label\">成功時PSR</div><div class=\"r-value\">${targetPSR.toFixed(3)}</div><div class=\"r-note\">${targetPSR <= 0.75 ? '買い圏内' : targetPSR <= 1.5 ? '適正圏' : '割高'}</div></div>\n <div class=\"result-card cyan\"><div class=\"r-label\">フィッシャー理論時価</div><div class=\"r-value\">${(fisherTheory/1000000000000).toFixed(1)}兆</div><div class=\"r-note\">売上×5%×PER15</div></div>\n <div class=\"result-card blue\"><div class=\"r-label\">理論株価</div><div class=\"r-value\">${fmtYen(fisherTheory / shares)}</div><div class=\"r-note\">フィッシャー基準</div></div>\n `;\n document.getElementById('fisher_results').innerHTML = fHTML;\n\n // Portfolio\n const pHTML = `\n <div class=\"result-card green\"><div class=\"r-label\">日産時価（成功時）</div><div class=\"r-value\">${(nissanNewValue/10000).toFixed(0)}万</div><div class=\"r-note\">現在 1,747万</div></div>\n <div class=\"result-card ${pfChange >= 0 ? 'green' : 'red'}\"><div class=\"r-label\">PF合計</div><div class=\"r-value\">${(pfTotal/10000).toFixed(0)}万</div><div class=\"r-note\">${fmtPct(pfChange)} (現在12,456万)</div></div>\n <div class=\"result-card gold\"><div class=\"r-label\">日産ウェイト</div><div class=\"r-value\">${nissanWeight.toFixed(1)}%</div><div class=\"r-note\">現在 14.0%</div></div>\n <div class=\"result-card cyan\"><div class=\"r-label\">PF増加額</div><div class=\"r-value\">${((pfTotal - 124560000)/10000).toFixed(0)}万</div><div class=\"r-note\">日産の寄与</div></div>\n `;\n document.getElementById('portfolio_results').innerHTML = pHTML;\n\n // Bars\n const divPct = DIV4_VALUE / pfTotal * 100;\n const nisPct = nissanNewValue / pfTotal * 100;\n document.getElementById('bar_div').style.width = divPct + '%';\n document.getElementById('bar_div_pct').textContent = divPct.toFixed(1) + '%';\n document.getElementById('bar_nissan').style.width = nisPct + '%';\n document.getElementById('bar_nissan_pct').textContent = nisPct.toFixed(1) + '%';\n\n // Timeline\n const stages = [\n { label: '現在（2025/04）', rev: 12.63, opmV: 0.6, note: '純損失▲6,709億' },\n { label: 'FY2025 予想', rev: 12.5, opmV: -2.0, note: '関税影響除きBE' },\n { label: 'FY2026 目標', rev: revenue, opmV: opm, note: 'Re:Nissan成功' },\n { label: 'FY2027 正常化', rev: revenue * 1.03, opmV: Math.min(opm + 1, 8), note: '工場統合完了' },\n ];\n\n let tbHTML = '';\n stages.forEach((s, i) => {\n const sRevBn = s.rev * 1000000000000;\n const sOP = sRevBn * (s.opmV / 100);\n const sNet = sOP * netRatio;\n const sEPS = i <= 1 ? null : sNet / shares;\n const sPrice = sEPS ? sEPS * per : (i === 0 ? CURRENT_NISSAN_PRICE : null);\n const sNisVal = sPrice ? NISSAN_SHARES_HELD * sPrice : null;\n const sPF = sNisVal ? DIV4_VALUE + sNisVal : null;\n\n const priceStr = sPrice ? fmtYen(sPrice) : (i === 1 ? '赤字' : '—');\n const nisValStr = sNisVal ? (sNisVal/10000).toFixed(0) + '万' : '—';\n const pfStr = sPF ? (sPF/10000).toFixed(0) + '万' : '—';\n const cls = i === 2 ? 'highlight' : '';\n\n tbHTML += `<tr class=\"${cls}\">\n <td class=\"year\">${s.label}</td>\n <td>${s.rev.toFixed(1)}兆</td>\n <td class=\"${s.opmV < 0 ? 'neg' : ''}\">${(sOP/100000000).toFixed(0)}億</td>\n <td class=\"${s.opmV < 0 ? 'neg' : ''}\">${s.opmV.toFixed(1)}%</td>\n <td>${priceStr}</td>\n <td>${nisValStr}</td>\n <td>${pfStr}</td>\n </tr>`;\n });\n document.getElementById('timeline_body').innerHTML = tbHTML;\n\n // Summary\n document.getElementById('summary_callout').innerHTML = `\n <strong>サマリー:</strong> Re:Nissan計画がFY2026に営業利益率${opm.toFixed(1)}%を達成し、市場がPER ${per.toFixed(0)}倍で評価した場合、日産株は現在の¥${CURRENT_NISSAN_PRICE.toFixed(0)}から¥${targetPrice.toFixed(0)}へ${fmtPct(upside)}。ポートフォリオ全体では12,456万→${(pfTotal/10000).toFixed(0)}万（${fmtPct(pfChange)}）。日産のPSRは${currentPSR.toFixed(3)}→${targetPSR.toFixed(3)}に正常化。<br><br>\n <strong>注意:</strong> FY2025は関税影響で営業損失▲2,000億円（Q1）の見通し。成功シナリオに至るまでにFY2025の谷を越える必要がある。フィッシャー基準の純利益率5%到達にはOPM ${(5/netRatio).toFixed(1)}%以上が必要。配当4銘柄（${(DIV4_VALUE/10000).toFixed(0)}万、${divPct.toFixed(0)}%）が下支えとなるポートフォリオ構造。\n `;\n}\n\n// Event listeners\n['sl_revenue','sl_opm','sl_per','sl_net_ratio','sl_shares'].forEach(id => {\n document.getElementById(id).addEventListener('input', calc);\n});\n\ncalc();\n</script>\n</body>\n</html>\n\n Enter fullscreen mode\n \n\n Exit fullscreen mode",
